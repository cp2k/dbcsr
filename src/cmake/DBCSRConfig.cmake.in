@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Hints for locating DBCSR's dependencies (override with your own -D flags)
set(DBCSR_LIBXSROOT "@LIBXSROOT@")
set(DBCSR_LIBXSTREAMROOT "@LIBXSTREAMROOT@")
set(DBCSR_LIBXSMMROOT "@LIBXSMMROOT@")

# the following should only be needed when building statically

set(DBCSR_USE_MPI @USE_MPI@)
if (@USE_MPI@)
  find_dependency(MPI)
endif ()

set(DBCSR_USE_OPENMP @USE_OPENMP@)
if (@USE_OPENMP@)
  find_dependency(OpenMP)
endif ()

set(DBCSR_USE_LIBXS @USE_LIBXS@)
if (@USE_LIBXS@)
  find_dependency(libxs CONFIG REQUIRED)
endif ()

set(DBCSR_USE_LIBXSMM @USE_LIBXSMM@)
if (@USE_LIBXSMM@)
  find_dependency(libxsmm CONFIG REQUIRED)
endif ()

set(DBCSR_USE_ACCEL @USE_ACCEL@)
if ("@USE_ACCEL@" MATCHES "cuda")
  enable_language(CUDA)
  find_dependency(CUDAToolkit)
endif ()

if ("@USE_ACCEL@" MATCHES "hip")
  enable_language(HIP)
  find_dependency(hip)
  find_dependency(hipblas)
  find_dependency(hiprtc)
endif ()

if ("@USE_ACCEL@" MATCHES "opencl")
  find_dependency(OpenCL)
endif ()

set(DBCSR_USE_LIBXSTREAM @USE_LIBXSTREAM@)
if (@USE_LIBXSTREAM@)
  find_dependency(libxstream CONFIG REQUIRED)
endif ()

include("${CMAKE_CURRENT_LIST_DIR}/DBCSRTargets.cmake")
